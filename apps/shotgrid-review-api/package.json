{
	"name": "shotgrid-review-api",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"dependencies": {
		"@tldraw/shotgrid-review-contracts": "workspace:*",
		"@tldraw/sync-core": "workspace:*",
		"@tldraw/tlschema": "workspace:*",
		"@tldraw/validate": "workspace:*",
		"react": "^19.2.1",
		"react-dom": "^19.2.1",
		"ws": "^8.18.0"
	},
	"scripts": {
		"dev": "yarn run -T tsx watch src/server.ts",
		"build": "yarn run -T tsgo --build tsconfig.json && yarn run -T esbuild src/server.ts --bundle --platform=node --format=esm --outfile=dist/server.js && yarn run -T esbuild src/ops/reviewDataSnapshotCli.ts --bundle --platform=node --format=esm --outfile=dist/review-data-snapshot.js",
		"lint": "yarn run -T tsx ../../internal/scripts/lint.ts",
		"review-data": "node dist/review-data-snapshot.js",
		"review-data:dev": "yarn run -T tsx src/ops/reviewDataSnapshotCli.ts",
		"start": "node dist/server.js",
		"test": "yarn run -T vitest run"
	},
	"devDependencies": {
		"@types/node": "^22.15.31",
		"@types/ws": "^8.18.1",
		"esbuild": "^0.28.0",
		"tsx": "^4.19.2",
		"typescript": "^5.8.3",
		"vitest": "^4.1.7"
	}
}
