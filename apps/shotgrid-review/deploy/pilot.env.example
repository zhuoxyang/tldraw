# Copy this non-secret configuration outside source control, replace every placeholder, and pass it
# with `docker compose --env-file <config-path> -f apps/shotgrid-review/deploy/compose.yaml up -d`.
# Keep the gateway on loopback behind the HTTPS/SSO ingress unless the host firewall and
# forward-auth boundary have been reviewed for a direct non-loopback binding.
#
# Do not add server secret values to this file. The organization secret manager must inject these
# five variables into the Docker Compose process environment immediately before each Compose
# command: SHOTGRID_SCRIPT_KEY, REVIEW_API_TRUSTED_PROXY_TOKEN, REVIEW_SYNC_SECRET,
# SHOTGRID_WEBHOOK_SECRET, and REVIEW_METRICS_TOKEN. Compose materializes them as /run/secrets
# mounts with the per-service ownership declared in compose.yaml; they are not service environment
# entries, build arguments, or image layers. This bundle targets `docker compose`; environment-
# backed secret sources are not supported by `docker stack deploy`.
#
# The tag-based Dockerfile/Compose defaults are for local evaluation only. A real pilot must set
# NODE_IMAGE, NGINX_IMAGE, and ALPINE_IMAGE to organization-registry image references pinned by an
# approved sha256 digest. Never deploy mutable public tags after the images have been reviewed.

REVIEW_APP_ORIGIN=https://review.example.invalid
REVIEW_BIND_ADDRESS=127.0.0.1
REVIEW_PORT=8080
REVIEW_FORWARD_AUTH_UPSTREAM=http://host.docker.internal:4180/oauth2/auth
REVIEW_FIXED_ACTOR_SUBJECT=oidc:replace-with-approved-pilot-subject
REVIEW_NETWORK_NAME=shotgrid-review-backend
REVIEW_DATA_VOLUME=shotgrid-review-data
REVIEW_BACKUP_VOLUME=shotgrid-review-backups
# Set a unique, empty volume name only while running the restore profile. After validation,
# promote it by assigning the same value to REVIEW_DATA_VOLUME and keeping the old volume intact.
REVIEW_RESTORE_VOLUME=shotgrid-review-restore-staging

NODE_IMAGE=registry.example.invalid/approved/node@sha256:replace-with-approved-digest
NGINX_IMAGE=registry.example.invalid/approved/nginx-unprivileged@sha256:replace-with-approved-digest
ALPINE_IMAGE=registry.example.invalid/approved/alpine@sha256:replace-with-approved-digest

VITE_REVIEW_STORAGE_NAMESPACE=shotgrid-pilot-v1
VITE_TLDRAW_LICENSE_KEY=replace-with-approved-license-key

SHOTGRID_SITE_URL=https://studio.shotgrid.autodesk.com
SHOTGRID_SCRIPT_NAME=replace-with-dedicated-script-name
SHOTGRID_SUDO_AS_LOGIN=pilot-reviewer@example.invalid
SHOTGRID_REVIEW_PROJECT_IDS=123
SHOTGRID_WEBHOOK_PROJECT_IDS=123
SHOTGRID_WEBHOOK_IDS=00000000-0000-4000-8000-000000000001
SHOTGRID_REVIEW_DECISIONS_JSON=[{"key":"approve","label":"Approve","statusCode":"apr"},{"key":"needs-changes","label":"Needs changes","statusCode":"chg"}]
SHOTGRID_REVIEW_VIDEO_FRAME_RATE_MODE=unknown

# Proxy, sync, webhook, and metrics secret values must be at least 32 characters. Use a
# base64url-safe proxy token because it is rendered into the runtime-only Nginx configuration.
