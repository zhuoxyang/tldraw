{
	"name": "shotgrid-review",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite --host 127.0.0.1 --port 5430",
		"build": "yarn run -T tsgo --build tsconfig.json && vite build",
		"e2e": "playwright test --config=e2e/playwright.config.ts",
		"lint": "yarn run -T tsx ../../internal/scripts/lint.ts",
		"test": "yarn run -T vitest run"
	},
	"dependencies": {
		"@tldraw/shotgrid-review-contracts": "workspace:*",
		"@tldraw/sync": "workspace:*",
		"react": "^19.2.1",
		"react-dom": "^19.2.1",
		"tldraw": "workspace:*"
	},
	"devDependencies": {
		"@playwright/test": "^1.61.0",
		"@types/node": "^22.15.31",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"fake-indexeddb": "^4.0.2",
		"typescript": "^5.8.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.7"
	}
}
